{
  "name": "blast-radius-analyzer",
  "display_name": "Blast Radius Analyzer",
  "description": "Trace cross-file dependencies using GitLab Orbit's knowledge graph. Mention @blast-radius with a file path in any issue or MR comment to see the full blast radius of code changes.",
  "version": "1.0.0",
  "type": "agent",
  "platform": "gitlab_duo_agent_platform",
  "tools": ["create_issue_comment"],
  "skill": "skills/blast-radius/SKILL.md",
  "visibility": "private",
  "system_prompt": {
    "file": "AGENTS.md",
    "summary": "You are a dependency analysis expert. Query GitLab Orbit's knowledge graph to find everything that depends on a given file or function. Return a structured risk report with DIRECT IMPACT, TRANSITIVE IMPACT, PROJECT IMPACT, and RISK SCORE."
  },
  "oracle_integration": {
    "remote": {
      "mcp_tools": ["get_graph_schema", "query_graph"],
      "auth": "gitlab_oauth"
    },
    "local_fallback": {
      "cli": "orbit",
      "script": "bin/blast-radius-local.sh"
    }
  },
  "risk_classification": {
    "low": {"direct_max": 2, "transitive_max": 0},
    "medium": {"direct_max": 10, "transitive_max": 5},
    "high": {"direct_max": 50, "transitive_max": 20},
    "critical": {"direct_max": null, "transitive_max": null}
  },
  "max_traversal_depth": 3,
  "cycle_detection": true,
  "deployment": {
    "gitlab_project": "prestige-worldwidest/blast-radius-agent",
    "github_repo": "tcconnally/blast-radius-agent",
    "ai_catalog": "https://gitlab.com/explore/ai-catalog/agents/"
  },
  "hackathon": {
    "event": "GitLab Transcend Hackathon 2026",
    "track": "Showcase",
    "devpost": "https://gitlab-transcend.devpost.com/"
  },
  "license": "MIT"
}
